{
  "name": "revenue-leakage-radar",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@rlr/web",
    "dev:web": "npm run dev --workspace=@rlr/web",
    "build": "npm run build --workspace=@rlr/web",
    "lint": "npm run lint --workspace=@rlr/web",
    "clerk:init": "cd apps/web && clerk init --app app_3FdbXDyolZYLnuPxsuNVlpAtgX2",
    "clerk:doctor": "cd apps/web && clerk doctor",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@clerk/testing": "^2.1.7",
    "@playwright/test": "^1.61.1",
    "dotenv": "^17.4.2"
  }
}
