# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://rlr:rlr_dev_password@localhost:5432/revenue_leakage_radar

# ── Redis (Celery) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Set true to run ingestion synchronously without a Celery worker (local dev)
CELERY_TASK_ALWAYS_EAGER=true
# Worker concurrency (production Railway: use 1–2; default auto-detect can OOM)
CELERY_WORKER_CONCURRENCY=2

# ── OpenAI (Sprint 2: column mapping) ─────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── API ───────────────────────────────────────────────────
ENVIRONMENT=development
# APP_ENV=production
DEV_UNLOCK_ENABLED=true
API_HOST=0.0.0.0
API_PORT=8000
API_URL=http://localhost:8000
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=250
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_HOSTS=*
STORAGE_BACKEND=local

# ── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WEB_URL=http://localhost:3000
WEB_URL=http://localhost:3000

# ── Clerk Authentication ───────────────────────────────────
# Keys from clerk init land in apps/web/.env.local (also loaded by the API).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here
CLERK_JWT_ISSUER=https://your-clerk-instance.clerk.accounts.dev
CLERK_JWT_AUDIENCE=http://localhost:3000
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ── Stripe (Sprint 5) ─────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Revenue Verification Report: configure Stripe Price at $2,500 one-time
STRIPE_PRICE_SINGLE_REPORT=price_...
# Alias supported: STRIPE_PAID_AUDIT_PRICE_ID=price_...
# Enterprise / legacy annual billing (optional; not shown on public pricing page)
STRIPE_PRICE_ANNUAL_MEMBERSHIP=price_...
ANNUAL_MEMBERSHIP_REPORT_CREDITS=12
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
SUPPORT_EMAIL=aaryan@paevo.co
FEEDBACK_EMAIL=aaryan@paevo.co
FROM_EMAIL=hello@paevo.co

# ── Cloudflare R2 (production) ────────────────────────────
# STORAGE_BACKEND=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# R2_BUCKET_UPLOADS=paevo-prod-uploads
# R2_BUCKET_REPORTS=paevo-prod-reports

# ── PostHog Analytics ───────────────────────────────────────
# Use the PROJECT API key (phc_...) from PostHog → Project Settings → Project API key.
# Do NOT use a personal API key (phx_...); it cannot capture events.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Sentry ──────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Resend (transactional email) ────────────────────────────
RESEND_API_KEY=

# ── E2E Testing (Playwright) ──────────────────────────────
# Optional overrides; defaults used when unset (see e2e/helpers/auth.ts)
# E2E_CLERK_USER_EMAIL=e2e-qa@revenueleakageradar.test
# E2E_CLERK_USER_PASSWORD=E2eQaTest!2026Secure
