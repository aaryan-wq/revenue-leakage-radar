# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://rlr:rlr_dev_password@localhost:5432/revenue_leakage_radar

# ── Redis (Celery) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Set true to run ingestion synchronously without a Celery worker (local dev)
CELERY_TASK_ALWAYS_EAGER=true

# ── OpenAI (Sprint 2: column mapping) ─────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── API ───────────────────────────────────────────────────
ENVIRONMENT=development
DEV_UNLOCK_ENABLED=true
API_HOST=0.0.0.0
API_PORT=8000
API_URL=http://localhost:8000
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=250
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Clerk Authentication ───────────────────────────────────
# Keys from clerk init land in apps/web/.env.local (also loaded by the API).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here
CLERK_JWT_ISSUER=https://your-clerk-instance.clerk.accounts.dev
CLERK_JWT_AUDIENCE=http://localhost:3000
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ── Stripe (Sprint 5) ─────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Revenue Verification Report: configure Stripe Price at $1,500 one-time
STRIPE_PRICE_SINGLE_REPORT=price_...
# Enterprise / legacy annual billing (not shown on public pricing page)
STRIPE_PRICE_ANNUAL_MEMBERSHIP=price_...
ANNUAL_MEMBERSHIP_REPORT_CREDITS=12
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_WEB_URL=http://localhost:3000
# API uses WEB_URL for Stripe redirect URLs; falls back to NEXT_PUBLIC_WEB_URL when unset
WEB_URL=http://localhost:3000
SUPPORT_EMAIL=contact@paevo.co

# ── PostHog Analytics ───────────────────────────────────────
# Use the PROJECT API key (phc_...) from PostHog → Project Settings → Project API key.
# Do NOT use a personal API key (phx_...); it cannot capture events.
# Region must match your PostHog project:
#   US cloud → https://us.i.posthog.com
#   EU cloud → https://eu.i.posthog.com
# Frontend keys MUST also be in apps/web/.env.local (Next.js bakes them at dev-server start).
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── E2E Testing (Playwright) ──────────────────────────────
# Optional overrides; defaults used when unset (see e2e/helpers/auth.ts)
# E2E_CLERK_USER_EMAIL=e2e-qa@revenueleakageradar.test
# E2E_CLERK_USER_PASSWORD=E2eQaTest!2026Secure
